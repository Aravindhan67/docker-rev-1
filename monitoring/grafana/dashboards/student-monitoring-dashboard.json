      "id": 24,
      "type": "stat",
      "title": "🧠 Node.js Heap Used",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"orange","value":100000000},{"color":"red","value":200000000}] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "nodejs_heap_size_used_bytes", "legendFormat": "Heap Used", "refId": "A" }]

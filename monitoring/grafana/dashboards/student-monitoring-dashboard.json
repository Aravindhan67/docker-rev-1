    {
      "id": 25,
      "type": "stat",
      "title": "🔄 GC Duration",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"orange","value":0.01},{"color":"red","value":0.1}] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "rate(nodejs_gc_duration_seconds_sum[1m])", "legendFormat": "GC Rate", "refId": "A" }]
    },

    {
      "id": 30,
      "type": "timeseries",
      "title": "🧠 Node.js Memory (Heap)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity", "showPoints": "auto" }
